# ═══════════════════════════════════════════════════════════
#  LEADWEB — Environment Variables
#  Copy this file to .env.local and fill in your real values.
# ═══════════════════════════════════════════════════════════

# Google Apps Script Web App URL (deployed URL)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Webhook secret — must match the value in Apps Script → Script Properties
WEBHOOK_SECRET=whsec_CHANGE_ME

# Brevo (Sendinblue) API Key
BREVO_API_KEY=xkeysib-YOUR_API_KEY_HERE

# Brevo Email Configuration
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME="Leadweb"
BREVO_PRIMARY_RECIPIENT=you@yourdomain.com
BREVO_BCC_RECIPIENTS=teammate@yourdomain.com
